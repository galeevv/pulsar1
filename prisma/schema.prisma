generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum PaymentRequestStatus {
  CREATED
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DeviceSlotStatus {
  FREE
  ACTIVE
  BLOCKED
}

enum IntegrationProvider {
  MARZBAN
}

enum IntegrationTargetType {
  SUBSCRIPTION
  DEVICE_SLOT
  PAYMENT_REQUEST
  USER
}

enum IntegrationSyncStatus {
  SUCCESS
  ERROR
}

enum PaymentMethod {
  PLATEGA
  CREDITS
}

enum PlategaWebhookLogStatus {
  RECEIVED
  PROCESSED
  IGNORED
  ERROR
}

model User {
  id                   String               @id @default(cuid())
  username             String               @unique
  passwordHash         String
  role                 Role                 @default(USER)
  credits              Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  inviteCodesUsed      InviteCode[]         @relation("InviteCodeUsedBy")
  referralCodesCreated ReferralCode[]       @relation("ReferralCodeOwner")
  referralCodeUse      ReferralCodeUse?     @relation("ReferralCodeUseByUser")
  paymentRequests      PaymentRequest[]
  subscriptions        Subscription[]
  supportMessages      SupportMessage[]     @relation("SupportMessageSender")
  supportTickets       SupportTicket[]
  promoCodeRedemptions PromoCodeRedemption[]
  sessions             Session[]
}

model InviteCode {
  id           String    @id @default(cuid())
  code         String    @unique
  isEnabled    Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  usedAt       DateTime?
  usedByUserId String?   @unique
  usedBy       User?     @relation("InviteCodeUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([isEnabled])
  @@index([expiresAt])
}

model ReferralCode {
  id            String            @id @default(cuid())
  code          String            @unique
  discountPct   Int               @default(50)
  rewardCredits Int               @default(100)
  isEnabled     Boolean           @default(true)
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  ownerUserId   String?
  ownerUser     User?             @relation("ReferralCodeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  uses          ReferralCodeUse[]

  @@index([isEnabled])
  @@index([expiresAt])
}

model ReferralCodeUse {
  id                  String       @id @default(cuid())
  referralCodeId      String
  referredUserId      String       @unique
  discountPctSnapshot Int
  rewardCreditsSnapshot Int
  rewardGrantedAt     DateTime?
  createdAt           DateTime     @default(now())
  referralCode        ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredUser        User         @relation("ReferralCodeUseByUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referralCodeId])
  @@index([rewardGrantedAt])
}

model PromoCode {
  id             String              @id @default(cuid())
  code           String              @unique
  creditAmount   Int
  maxRedemptions Int
  isEnabled      Boolean             @default(true)
  expiresAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  redemptions    PromoCodeRedemption[]

  @@index([isEnabled])
  @@index([expiresAt])
}

model PromoCodeRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  createdAt   DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([promoCodeId])
  @@index([userId])
}

model ReferralProgramSettings {
  id                 Int      @id @default(1)
  isEnabled          Boolean  @default(true)
  defaultDiscountPct Int      @default(50)
  defaultRewardCredits Int    @default(100)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model LegalDocumentSettings {
  id                Int      @id @default(1)
  userAgreementText String   @default("")
  publicOfferText   String   @default("")
  privacyPolicyText String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ServiceCapacitySettings {
  id                     Int      @id @default(1)
  maxActiveSubscriptions Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model SupportTicket {
  id              Int              @id @default(autoincrement())
  userId          String           @map("user_id")
  subject         String
  category        String
  status          String           @default("open")
  priority        String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  lastMessageAt   DateTime?        @map("last_message_at")
  closedAt        DateTime?        @map("closed_at")
  adminLastReadAt DateTime?        @map("admin_last_read_at")
  userLastReadAt  DateTime?        @map("user_last_read_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
  @@index([userId, status, lastMessageAt])
  @@map("support_tickets")
}

model SupportMessage {
  id         Int          @id @default(autoincrement())
  ticketId   Int          @map("ticket_id")
  senderType String       @map("sender_type")
  senderId   String?      @map("sender_id")
  message    String
  createdAt  DateTime     @default(now()) @map("created_at")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender     User?        @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([createdAt])
  @@index([ticketId, createdAt])
  @@map("support_messages")
}

model SubscriptionDurationRule {
  id              String   @id @default(cuid())
  months          Int      @unique
  monthlyPrice    Int      @default(299)
  discountPercent Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

model SubscriptionPricingSettings {
  id                     Int      @id @default(1)
  minDevices             Int      @default(1)
  maxDevices             Int      @default(5)
  baseDeviceMonthlyPrice Int      @default(299)
  extraDeviceMonthlyPrice Int     @default(100)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PaymentRequest {
  id                                  String               @id @default(cuid())
  userId                              String
  tariffName                          String
  periodMonths                        Int
  deviceLimit                         Int
  amountRub                           Int
  status                              PaymentRequestStatus @default(CREATED)
  method                              PaymentMethod        @default(PLATEGA)
  months                              Int                  @default(1)
  devices                             Int                  @default(1)
  currency                            String               @default("RUB")
  baseDeviceMonthlyPriceSnapshot      Int                  @default(0)
  extraDeviceMonthlyPriceSnapshot     Int                  @default(0)
  monthlyPriceSnapshot                Int                  @default(0)
  durationDiscountPercentSnapshot     Int                  @default(0)
  referralDiscountPercentSnapshot     Int                  @default(0)
  totalPriceBeforeDiscountRubSnapshot Int                  @default(0)
  createdAt                           DateTime             @default(now())
  updatedAt                           DateTime             @updatedAt
  markedPaidAt                        DateTime?
  approvedAt                          DateTime?
  rejectedAt                          DateTime?
  plategaTransactionId                String?              @unique
  plategaRedirectUrl                  String?
  plategaStatus                       String?
  plategaPayloadJson                  String?
  plategaConfirmedAt                  DateTime?
  user                                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription                        Subscription?
  plategaWebhookLogs                  PlategaWebhookLog[]

  @@index([userId])
  @@index([status])
  @@index([method])
  @@index([createdAt])
}

model PlategaWebhookLog {
  id               String                 @id @default(cuid())
  dedupKey         String                 @unique
  transactionId    String
  paymentRequestId String?
  statusRaw        String
  payloadJson      String
  headersJson      String?
  processingStatus PlategaWebhookLogStatus @default(RECEIVED)
  errorMessage     String?
  processedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  paymentRequest   PaymentRequest?        @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)

  @@index([transactionId, createdAt])
  @@index([paymentRequestId])
  @@index([processingStatus, createdAt])
}

model Subscription {
  id                              String             @id @default(cuid())
  userId                          String
  paymentRequestId                String?            @unique
  tariffName                      String
  periodMonths                    Int
  deviceLimit                     Int
  devices                         Int                @default(1)
  pendingDevices                  Int?
  startsAt                        DateTime?
  expiresAt                       DateTime?
  monthsPurchased                 Int                @default(1)
  totalPaid                       Int                @default(0)
  currency                        String             @default("RUB")
  baseDeviceMonthlyPriceSnapshot  Int                @default(0)
  extraDeviceMonthlyPriceSnapshot Int                @default(0)
  monthlyPriceSnapshot            Int                @default(0)
  durationDiscountPercentSnapshot Int                @default(0)
  referralDiscountPercentSnapshot Int                @default(0)
  status                          SubscriptionStatus @default(ACTIVE)
  startedAt                       DateTime
  endsAt                          DateTime
  revokedAt                       DateTime?
  marzbanUsername                 String?            @unique
  marzbanStatus                   String?
  marzbanDataJson                 String?
  provisionedAt                   DateTime?
  lastSyncAt                      DateTime?
  lastSyncError                   String?
  subscriptionUrl                 String?
  createdAt                       DateTime           @default(now())
  updatedAt                       DateTime           @updatedAt
  user                            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentRequest                  PaymentRequest?    @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)
  deviceSlots                     DeviceSlot[]

  @@index([userId])
  @@index([status])
  @@index([endsAt])
  @@index([expiresAt])
}

model DeviceSlot {
  id             String           @id @default(cuid())
  subscriptionId String
  slotIndex      Int
  status         DeviceSlotStatus @default(FREE)
  label          String?
  marzbanUsername String?
  configUrl      String?
  lastSyncAt     DateTime?
  lastSyncError  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  subscription   Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, slotIndex])
  @@index([status])
}

model IntegrationSyncLog {
  id          String                @id @default(cuid())
  provider    IntegrationProvider
  operation   String
  targetType  IntegrationTargetType
  targetId    String
  status      IntegrationSyncStatus
  requestJson String?
  responseJson String?
  errorMessage String?
  createdAt   DateTime              @default(now())

  @@index([provider, createdAt])
  @@index([targetType, targetId])
  @@index([status, createdAt])
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}
